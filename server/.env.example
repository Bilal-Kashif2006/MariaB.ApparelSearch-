# Copy this file to .env and fill in your own keys. Never commit the real .env.
GROQ_API_KEY=

# Used for text/JSON intent planning (both typed and voice search route
# through this). Groq above is only used for Whisper audio transcription now.
# Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Locks the proxy down to your own extension so a random website open in
# your browser can't POST audio to it and burn your Groq quota. Load the
# unpacked extension, open chrome://extensions, copy the ID shown under it,
# then set this to chrome-extension://<that-id>. Left unset, the proxy
# accepts any origin (fine for a first run, not recommended after that).
ALLOWED_EXTENSION_ORIGIN=

# Optional overrides — defaults shown.
# PORT=8787
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# GEMINI_INTENT_MODEL=gemini-2.5-flash

# Verbose model diagnostics. Useful while troubleshooting; set false after
# the proxy is working normally.
# VERBOSE_LLM_LOGS=true
